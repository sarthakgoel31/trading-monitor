# TradingView Pro credentials (for live data — without these, falls back to yfinance)
TV_USERNAME=your_tv_username
TV_PASSWORD=your_tv_password

# Reddit API (optional — create app at https://www.reddit.com/prefs/apps)
# REDDIT_CLIENT_ID=your_reddit_client_id
# REDDIT_CLIENT_SECRET=your_reddit_client_secret
# REDDIT_USER_AGENT=trading-monitor/1.0

# Analysis parameters (optional, defaults shown)
# RSI_PERIOD=14
# POLL_INTERVAL_SECONDS=300
# SENTIMENT_CACHE_SECONDS=900
